{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TMP Benchmark Run",
  "type": "object",
  "required": [
    "run_id",
    "task_id",
    "mode",
    "surface",
    "tool_calls",
    "input_tokens",
    "output_tokens",
    "wall_time_ms",
    "success",
    "invalid_operation_attempted",
    "user_clarifications",
    "failed_attempts"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "baseline",
        "tmp_assisted",
        "tmp_completion",
        "tmp_registry",
        "tmp_generated_schema",
        "tmp_output_policy",
        "tmp_rtk",
        "tmp_generated_rtk_filter"
      ]
    },
    "surface": {
      "type": "string",
      "enum": [
        "cli",
        "completion",
        "api",
        "sql",
        "workflow",
        "script",
        "output_policy",
        "registry",
        "failure"
      ]
    },
    "agent": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "tool_calls": {
      "type": "integer",
      "minimum": 0
    },
    "input_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "raw_output_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "shaped_output_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "output_signal_preserved": {
      "type": "boolean"
    },
    "output_compressor": {
      "type": "string",
      "enum": ["none", "tmp_builtin", "rtk", "rtk_generated_filter", "external"]
    },
    "rtk_supported": {
      "type": "boolean"
    },
    "generated_filter_reviewed": {
      "type": "boolean"
    },
    "generated_filter_verified": {
      "type": "boolean"
    },
    "wall_time_ms": {
      "type": "integer",
      "minimum": 0
    },
    "success": {
      "type": "boolean"
    },
    "invalid_operation_attempted": {
      "type": "boolean"
    },
    "user_clarifications": {
      "type": "integer",
      "minimum": 0
    },
    "failed_attempts": {
      "type": "integer",
      "minimum": 0
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
